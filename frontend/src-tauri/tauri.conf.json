{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ingestor",
  "mainBinaryName": "ingestor-desktop",
  "version": "0.1.4",
  "identifier": "com.arib.ingestor",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420 --strictPort",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build && npm run build:backend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ingestor",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:8765; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "createUpdaterArtifacts": true,
    "resources": {
      "binaries": "binaries",
      "../../skills": "skills"
    },
    "windows": {
      "wix": {
        "upgradeCode": "062e5893-99db-5d70-b11b-3c820b3344b7",
        "template": "./windows/installer.wxs",
        "language": {
          "en-US": {
            "localePath": "./windows/locales/en-US.wxl"
          }
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0NDg5NDU1NEY3OUNGNjcKUldSbnozbFBWWlJJaEhEelkvQ2l3RWphcURUcmZ4MHB6K25yQUZ0dTZyY0cwL213cmNWeTJvZ0UK",
      "endpoints": [
        "https://github.com/aribbabar/ingestor/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
