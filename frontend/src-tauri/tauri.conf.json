{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ingestor",
  "mainBinaryName": "ingestor-desktop",
  "version": "0.1.0",
  "identifier": "com.arib.ingestor",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420 --strictPort",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build && npm run build:backend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ingestor",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "binaries": "binaries",
      "../../skills": "skills"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
